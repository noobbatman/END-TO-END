# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME="Document Intelligence Platform"
APP_ENV=local          # local | staging | production
DEBUG=false
LOG_LEVEL=INFO
PIPELINE_VERSION=0.3.0
API_V1_PREFIX=/api/v1

# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/docintel
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── Celery ──────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# ── Storage ─────────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local           # local | s3
UPLOAD_DIR=data/uploads
EXPORT_DIR=data/exports

# S3 / MinIO (only needed when STORAGE_BACKEND=s3)
#S3_ENDPOINT_URL=http://localhost:9000    # omit for real AWS
#S3_ACCESS_KEY_ID=minioadmin
#S3_SECRET_ACCESS_KEY=minioadmin
#S3_BUCKET_UPLOADS=docintel-uploads
#S3_BUCKET_EXPORTS=docintel-exports
#S3_REGION=us-east-1

# ── OCR ─────────────────────────────────────────────────────────────────────────
OCR_ENGINE=tesseract            # tesseract | paddle
SPACY_MODEL=en_core_web_sm

# ── Pipeline ────────────────────────────────────────────────────────────────────
LOW_CONFIDENCE_THRESHOLD=0.75
MAX_UPLOAD_SIZE_MB=50

# ── Auth ─────────────────────────────────────────────────────────────────────────
# Leave empty to disable API key enforcement (local dev)
API_KEYS=
API_KEY_HEADER=X-API-Key

# ── Rate Limiting ────────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_UPLOAD_PER_MINUTE=30
RATE_LIMIT_DEFAULT_PER_MINUTE=120

# ── Webhooks ─────────────────────────────────────────────────────────────────────
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT_SECONDS=10
