# Host-machine local defaults
# Use this if you want to run FastAPI / Celery directly on your machine instead of inside docker containers.

APP_NAME="Document Intelligence Platform"
APP_ENV=local
DEBUG=false
LOG_LEVEL=INFO
PIPELINE_VERSION=0.3.0
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=*

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/docintel
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600
REDIS_RATE_LIMIT_URL=

STORAGE_BACKEND=local
UPLOAD_DIR=data/uploads
EXPORT_DIR=data/exports

OCR_ENGINE=tesseract
SPACY_MODEL=en_core_web_sm
LOW_CONFIDENCE_THRESHOLD=0.75
MAX_UPLOAD_SIZE_MB=50

API_KEYS=
API_KEY_HEADER=X-API-Key

RATE_LIMIT_ENABLED=true
RATE_LIMIT_UPLOAD_PER_MINUTE=30
RATE_LIMIT_DEFAULT_PER_MINUTE=120

WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT_SECONDS=10

LLM_EXTRACTION_ENABLED=false
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_FOLDER=INBOX
EMAIL_MAX_ATTACHMENTS_PER_RUN=50
