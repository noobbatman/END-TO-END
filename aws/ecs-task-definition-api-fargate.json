{
  "family": "docintel-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "__EXECUTION_ROLE_ARN__",
  "taskRoleArn": "__TASK_ROLE_ARN__",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "__IMAGE_URI__",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "command": [
        "uvicorn",
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--workers",
        "4"
      ],
      "environment": [
        {
          "name": "APP_ENV",
          "value": "production"
        },
        {
          "name": "APP_NAME",
          "value": "Document Intelligence Platform"
        },
        {
          "name": "STORAGE_BACKEND",
          "value": "s3"
        },
        {
          "name": "S3_REGION",
          "value": "__AWS_REGION__"
        },
        {
          "name": "S3_BUCKET_UPLOADS",
          "value": "__S3_BUCKET_UPLOADS__"
        },
        {
          "name": "S3_BUCKET_EXPORTS",
          "value": "__S3_BUCKET_EXPORTS__"
        },
        {
          "name": "LOG_LEVEL",
          "value": "INFO"
        },
        {
          "name": "DEBUG",
          "value": "false"
        },
        {
          "name": "DB_POOL_SIZE",
          "value": "10"
        },
        {
          "name": "CELERY_TASK_SOFT_TIME_LIMIT",
          "value": "300"
        },
        {
          "name": "CELERY_TASK_TIME_LIMIT",
          "value": "600"
        },
        {
          "name": "RATE_LIMIT_ENABLED",
          "value": "true"
        },
        {
          "name": "RATE_LIMIT_UPLOAD_PER_MINUTE",
          "value": "30"
        },
        {
          "name": "RATE_LIMIT_DEFAULT_PER_MINUTE",
          "value": "120"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "__DATABASE_URL_SECRET_ARN__"
        },
        {
          "name": "CELERY_BROKER_URL",
          "valueFrom": "__CELERY_BROKER_SECRET_ARN__"
        },
        {
          "name": "CELERY_RESULT_BACKEND",
          "valueFrom": "__CELERY_RESULT_BACKEND_SECRET_ARN__"
        },
        {
          "name": "API_KEYS",
          "valueFrom": "__API_KEYS_SECRET_ARN__"
        },
        {
          "name": "WEBHOOK_SECRET",
          "valueFrom": "__WEBHOOK_SECRET_ARN__"
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "valueFrom": "__ANTHROPIC_API_KEY_SECRET_ARN__"
        },
        {
          "name": "EMAIL_ADDRESS",
          "valueFrom": "__EMAIL_ADDRESS_SECRET_ARN__"
        },
        {
          "name": "EMAIL_PASSWORD",
          "valueFrom": "__EMAIL_PASSWORD_SECRET_ARN__"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/docintel-api",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -sf http://localhost:8000/api/v1/health/ready || exit 1"
        ],
        "interval": 15,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ],
  "tags": [
    {
      "key": "Environment",
      "value": "production"
    },
    {
      "key": "Service",
      "value": "api"
    }
  ]
}
